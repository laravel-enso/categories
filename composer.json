        "laravel-enso/data-import": "^5.0",
        "laravel-enso/dynamic-methods": "^4.0",
        "laravel-enso/files": "^5.0",
        "laravel-enso/helpers": "^4.0",
        "laravel-enso/forms": "^5.0",
        "laravel-enso/migrator": "^2.1",
        "laravel-enso/permissions": "^5.0",
        "laravel-enso/products": "^5.0",
        "laravel-enso/rememberable": "^4.0",
