{
    "name": "laravel-enso/categories",
    "type": "library",
    "description": "Hierarchical category management for Laravel Enso",
    "authors": [
        {
            "name": "Adrian Ocneanu",
            "email": "aocneanu@gmail.com",
            "homepage": "https://laravel-enso.com",
            "role": "Developer"
        }
    ],
    "keywords": [
        "laravel",
